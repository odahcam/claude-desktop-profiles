#!/bin/zsh
# cdp — Claude Desktop Profiles
#
# Runs multiple Claude Desktop accounts side by side on macOS by giving each
# profile its own --user-data-dir, and makes each profile launchable from
# Spotlight in two ways:
#
#   1. A per-profile launcher app:  "Claude Work.app", "Claude Personal.app"
#   2. A single chooser app:        "Claude Profiles.app" — a native picker
#      dialog that lists every profile (plus your default install) and can
#      also add and remove profiles without touching the terminal.
#
# Profiles are discovered by convention, not by a registry file: any folder
# matching ~/Library/Application Support/Claude-<Name> is a profile. Delete
# the folder and the launcher app, and the profile is gone.
#
# The chooser bundles a copy of this script in its Resources and shells out
# to it for add/remove, so GUI and CLI share one implementation.
#
# No dependencies beyond what ships with macOS (osacompile, PlistBuddy).

set -euo pipefail

# Resolved at file scope: inside functions zsh rebinds $0 to the function name
# (FUNCTION_ARGZERO), which would break the self-copy into the chooser bundle.
SCRIPT_PATH="${0:A}"

APP_SUPPORT="$HOME/Library/Application Support"
LAUNCHER_DIR="$HOME/Applications"
BUNDLE_PREFIX="com.claude-desktop-profiles"
CHOOSER_NAME="Claude Profiles"

# ---- helpers ---------------------------------------------------------------

err()  { print -u2 -- "✗ $*"; exit 1 }
ok()   { print -- "✓ $*" }
info() { print -- "ℹ $*" }

find_claude_app() {
  local c
  for c in "/Applications/Claude.app" "$HOME/Applications/Claude.app"; do
    [[ -d "$c" ]] && { print -- "$c"; return }
  done
  err "Claude.app not found in /Applications or ~/Applications."
}

# "client acme" -> slug "client-acme", display "Client Acme"
slugify() {
  print -- "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g'
}

displayify() {
  local out=() part
  for part in ${(s:-:)1}; do out+=("${(C)part}"); done
  print -- "${(j: :)out}"
}

# Compile an AppleScript source file into a .app with our bundle id and the
# Claude icon, replacing any existing bundle at that path.
compile_launcher() {
  local src="$1" app_path="$2" bundle_id="$3" claude_app="$4"

  [[ -d "$app_path" ]] && rm -rf "$app_path"
  mkdir -p "${app_path:h}"
  /usr/bin/osacompile -o "$app_path" "$src"

  local plist="$app_path/Contents/Info.plist"
  /usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier $bundle_id" "$plist" 2>/dev/null ||
    /usr/libexec/PlistBuddy -c "Add :CFBundleIdentifier string $bundle_id" "$plist"

  # Reuse Claude's own icon so the launcher is recognizable in Spotlight/Dock.
  local icns
  icns=$(print -l -- "$claude_app/Contents/Resources"/*.icns(N) | head -1)
  if [[ -n "$icns" && -f "$app_path/Contents/Resources/applet.icns" ]]; then
    cp "$icns" "$app_path/Contents/Resources/applet.icns"
    /usr/bin/touch "$app_path"
  fi

  # Editing Info.plist/Resources above broke osacompile's ad-hoc signature
  # seal; without a fresh signature Gatekeeper can report the app as damaged.
  /usr/bin/codesign --force --sign - "$app_path" 2>/dev/null || true
}

profile_dirs() {
  print -l -- "$APP_SUPPORT"/Claude-*(N/)
}

# When the chooser/GUI app invokes us (CDP_FROM_CHOOSER=1) we must not rebuild
# the chooser: we'd be rm -rf'ing the bundle that is currently running us.
# We also skip when the installed "Claude Profiles" is the compiled SwiftUI
# app — rebuilding would silently downgrade it to the AppleScript dialog.
rebuild_chooser_unless_nested() {
  [[ "${CDP_FROM_CHOOSER:-}" == "1" ]] && return 0
  [[ -x "$LAUNCHER_DIR/$CHOOSER_NAME.app/Contents/MacOS/ClaudeProfiles" ]] && return 0
  cmd_chooser --quiet
}

# ---- commands ---------------------------------------------------------------

cmd_add() {
  local raw="${1:-}"
  [[ -n "$raw" ]] || err "Usage: cdp add <name>   (e.g. cdp add personal)"
  local slug display data_dir app_path claude_app
  slug=$(slugify "$raw")
  [[ -n "$slug" ]] || err "Name must contain at least one letter or digit."
  display=$(displayify "$slug")
  data_dir="$APP_SUPPORT/Claude-$display"
  app_path="$LAUNCHER_DIR/Claude $display.app"
  claude_app=$(find_claude_app)

  mkdir -p "$data_dir"

  # The launcher runs `open -n` so a new instance starts even when another
  # Claude is already running; without -n macOS routes the request to the
  # existing window and ignores --user-data-dir.
  local tmp
  tmp=$(mktemp -d)
  cat > "$tmp/launcher.applescript" <<EOF
do shell script "open -n -a '$claude_app' --args --user-data-dir='$data_dir' > /dev/null 2>&1 &"
EOF
  compile_launcher "$tmp/launcher.applescript" "$app_path" "$BUNDLE_PREFIX.$slug" "$claude_app"
  rm -rf "$tmp"

  ok "Profile '$display' created."
  info "Data folder:  $data_dir"
  info "Launcher:     $app_path  (Spotlight: 'Claude $display')"
  print
  info "First launch: QUIT every other Claude window first (the claude:// login"
  info "deep link lands on whichever instance is running), open the launcher,"
  info "sign in, done. After that all profiles can run simultaneously."

  rebuild_chooser_unless_nested
}

cmd_chooser() {
  local claude_app tmp
  claude_app=$(find_claude_app)
  tmp=$(mktemp -d)

  # The chooser discovers profiles at runtime by listing Claude-* folders, so
  # it never needs rebuilding when profiles change — we rebuild on `cdp add`
  # only to keep the bundled cdp copy, icon, and signature fresh.
  cat > "$tmp/chooser.applescript" <<'EOF'
property addLabel : "+   Add a profile…"
property removeLabel : "–   Remove a profile…"

on run
	set appSupport to POSIX path of (path to application support folder from user domain)
	repeat
		set names to profileNames(appSupport)
		set opts to {"Default"}
		repeat with n in names
			set end of opts to contents of n
		end repeat
		set end of opts to addLabel
		if (count of names) > 0 then set end of opts to removeLabel
		set choice to choose from list opts with title "Claude Profiles" with prompt "Launch Claude with profile:" default items {"Default"}
		if choice is false then return
		set choice to (item 1 of choice) as text
		if choice is addLabel then
			addProfile()
		else if choice is removeLabel then
			removeProfile(appSupport)
		else if choice is "Default" then
			do shell script "open -a Claude"
			return
		else
			set dataDir to appSupport & "Claude-" & choice
			do shell script "open -n -a Claude --args --user-data-dir=" & quoted form of dataDir & " > /dev/null 2>&1 &"
			return
		end if
	end repeat
end run

on profileNames(appSupport)
	set raw to do shell script "ls -d " & quoted form of appSupport & "Claude-*/ 2>/dev/null | sed 's|/$||; s|.*/Claude-||' ; true"
	if raw is "" then return {}
	return paragraphs of raw
end profileNames

-- The cdp script bundled inside this app's Resources. GUI actions shell out
-- to it so the CLI and the chooser share one implementation.
on cdpCommand()
	return "CDP_FROM_CHOOSER=1 /bin/zsh " & quoted form of (POSIX path of (path to me) & "Contents/Resources/cdp")
end cdpCommand

on addProfile()
	set dlg to display dialog "Profile name (e.g. personal, client-acme):" default answer "" with title "Add Claude profile"
	set rawName to text returned of dlg
	if rawName is "" then return
	try
		do shell script cdpCommand() & " add " & quoted form of rawName
	on error msg
		display alert "Could not create profile" message msg as critical
		return
	end try
	display dialog "Profile created — it's now in the list, and 'Claude " & rawName & "' is searchable in Spotlight." & return & return & "Before its FIRST sign-in: quit every other Claude window. The login link lands on whichever instance is running." with title "Add Claude profile" buttons {"OK"} default button "OK"
end addProfile

on removeProfile(appSupport)
	set names to profileNames(appSupport)
	if names is {} then return
	set sel to choose from list names with title "Remove Claude profile" with prompt "Which profile?"
	if sel is false then return
	set target to (item 1 of sel) as text
	set btn to button returned of (display dialog "Remove \"" & target & "\"?" & return & return & "Launcher Only deletes the Spotlight app but keeps chats, login, and settings — the profile stays in this list and can be launched or fully removed later." & return & return & "Delete Everything also erases the data folder. Permanent." with title "Remove Claude profile" buttons {"Cancel", "Delete Everything", "Launcher Only"} default button "Launcher Only" cancel button "Cancel")
	set flag to "--keep-data"
	if btn is "Delete Everything" then
		set check to display dialog "Really delete ALL data for \"" & target & "\" — chats, login, settings? This cannot be undone." with title "Remove Claude profile" buttons {"Cancel", "Delete"} default button "Cancel" cancel button "Cancel"
		set flag to "--delete-data"
	end if
	try
		do shell script cdpCommand() & " remove " & quoted form of target & " " & flag
	on error msg
		display alert "Could not remove profile" message msg as critical
	end try
end removeProfile
EOF
  compile_launcher "$tmp/chooser.applescript" "$LAUNCHER_DIR/$CHOOSER_NAME.app" "$BUNDLE_PREFIX.chooser" "$claude_app"
  rm -rf "$tmp"

  # Bundle this script so the chooser's add/remove buttons drive the exact
  # same code path as the CLI, then re-sign (the copy broke the seal again).
  cp "$SCRIPT_PATH" "$LAUNCHER_DIR/$CHOOSER_NAME.app/Contents/Resources/cdp"
  chmod +x "$LAUNCHER_DIR/$CHOOSER_NAME.app/Contents/Resources/cdp"
  /usr/bin/codesign --force --sign - "$LAUNCHER_DIR/$CHOOSER_NAME.app" 2>/dev/null || true

  [[ "${1:-}" == "--quiet" ]] || ok "Chooser rebuilt: $LAUNCHER_DIR/$CHOOSER_NAME.app  (Spotlight: '$CHOOSER_NAME')"
}

cmd_gui() {
  # Compiles app/ClaudeProfiles.swift into a real .app, replacing the
  # AppleScript chooser at the same Spotlight name. Built locally on the
  # user's machine, so there is no notarization/quarantine problem.
  command -v swiftc >/dev/null 2>&1 ||
    err "swiftc not found. Install Xcode Command Line Tools (xcode-select --install), or use 'cdp chooser' for the dialog-based picker."
  local repo_root="${SCRIPT_PATH:h:h}"
  local src="$repo_root/app/ClaudeProfiles.swift"
  [[ -f "$src" ]] ||
    err "GUI source not found at $src — run cdp from a repo checkout to build the GUI."

  local claude_app app tmp bundle
  claude_app=$(find_claude_app)
  app="$LAUNCHER_DIR/$CHOOSER_NAME.app"
  tmp=$(mktemp -d)
  bundle="$tmp/$CHOOSER_NAME.app"
  mkdir -p "$bundle/Contents/MacOS" "$bundle/Contents/Resources"

  info "Compiling ClaudeProfiles.swift (first build can take ~30s)…"
  swiftc -O -parse-as-library -target "$(uname -m)-apple-macos13.0" \
    -o "$bundle/Contents/MacOS/ClaudeProfiles" "$src"

  cat > "$bundle/Contents/Info.plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key><string>$CHOOSER_NAME</string>
	<key>CFBundleDisplayName</key><string>$CHOOSER_NAME</string>
	<key>CFBundleIdentifier</key><string>$BUNDLE_PREFIX.gui</string>
	<key>CFBundleExecutable</key><string>ClaudeProfiles</string>
	<key>CFBundleIconFile</key><string>AppIcon</string>
	<key>CFBundlePackageType</key><string>APPL</string>
	<key>CFBundleShortVersionString</key><string>1.0.0</string>
	<key>LSMinimumSystemVersion</key><string>13.0</string>
	<key>NSHighResolutionCapable</key><true/>
</dict>
</plist>
EOF

  local icns
  icns=$(print -l -- "$claude_app/Contents/Resources"/*.icns(N) | head -1)
  [[ -n "$icns" ]] && cp "$icns" "$bundle/Contents/Resources/AppIcon.icns"

  # Same trick as the chooser: bundle this script so the GUI's add/remove
  # drive the exact same code path as the CLI.
  cp "$SCRIPT_PATH" "$bundle/Contents/Resources/cdp"
  chmod +x "$bundle/Contents/Resources/cdp"

  /usr/bin/codesign --force --sign - "$bundle" 2>/dev/null || true

  mkdir -p "$LAUNCHER_DIR"
  rm -rf "$app"
  mv "$bundle" "$app"
  rm -rf "$tmp"
  ok "GUI installed: $app  (Spotlight: '$CHOOSER_NAME')"
}

cmd_list() {
  local d found=0
  for d in "$APP_SUPPORT"/Claude-*(N/); do
    found=1
    local display="${${d:t}#Claude-}"
    local app="$LAUNCHER_DIR/Claude $display.app"
    if [[ -d "$app" ]]; then
      print -- "  $display\t$d\t(launcher ok)"
    else
      print -- "  $display\t$d\t(launcher MISSING — run: cdp add $(slugify "$display"))"
    fi
  done
  (( found )) || info "No profiles yet. Create one with: cdp add <name>"
}

cmd_remove() {
  local raw="${1:-}" mode="${2:-}"
  [[ -n "$raw" ]] || err "Usage: cdp remove <name> [--keep-data|--delete-data]"
  local display data_dir app_path
  display=$(displayify "$(slugify "$raw")")
  data_dir="$APP_SUPPORT/Claude-$display"
  app_path="$LAUNCHER_DIR/Claude $display.app"

  [[ -d "$app_path" ]] && { rm -rf "$app_path"; ok "Deleted launcher $app_path" }

  if [[ -d "$data_dir" ]]; then
    case "$mode" in
      --delete-data)
        rm -rf "$data_dir"
        ok "Deleted $data_dir"
        ;;
      --keep-data)
        info "Data folder kept: $data_dir"
        ;;
      *)
        print -n -- "Also delete data folder $data_dir (chats, login — permanent)? [y/N] "
        read -r answer
        if [[ "$answer" == [yY]* ]]; then
          rm -rf "$data_dir"
          ok "Deleted $data_dir"
        else
          info "Data folder kept. Re-create the launcher later with: cdp add $raw"
        fi
        ;;
    esac
  fi
  rebuild_chooser_unless_nested
}

cmd_help() {
  cat <<'EOF'
cdp — run multiple Claude Desktop accounts side by side on macOS

USAGE
  cdp add <name>      Create a profile + Spotlight launcher (e.g. cdp add personal)
  cdp list            List profiles and launcher health
  cdp remove <name>   Remove a profile's launcher; add --keep-data or
                      --delete-data to skip the interactive question
  cdp gui             Build + install the "Claude Profiles" SwiftUI app
                      (needs Xcode Command Line Tools; run from repo checkout)
  cdp chooser         Build the AppleScript picker instead — zero build
                      requirements, same Spotlight name, fewer looks
  cdp help            This text

Profiles live in ~/Library/Application Support/Claude-<Name>.
Launchers live in ~/Applications and are indexed by Spotlight.
EOF
}

# ---- dispatch ---------------------------------------------------------------

case "${1:-help}" in
  add)     shift; cmd_add "$@" ;;
  list)    cmd_list ;;
  remove)  shift; cmd_remove "$@" ;;
  gui)     cmd_gui ;;
  chooser) cmd_chooser ;;
  help|-h|--help) cmd_help ;;
  *) err "Unknown command: $1 (try: cdp help)" ;;
esac
